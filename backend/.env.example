# MongoDB Atlas Connection
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/portfolio-learning?retryWrites=true&w=majority

# Server Port
PORT=5000

# Environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5174
